generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum UploadStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RarityLevel {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String     @unique @db.VarChar(30)
  email              String     @unique @db.VarChar(120)
  passwordHash       String     @map("password_hash") @db.Text
  role               Role       @default(USER)
  contributorPoints  Int        @default(0) @map("contributor_points")
  streakDays         Int        @default(0) @map("streak_days")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @default(now()) @updatedAt @map("updated_at")

  files              File[]
  uploads            Upload[]
  downloads          Download[]
  adminLogs          AdminLog[]

  @@map("users")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique @db.VarChar(80)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  files       File[]

  @@map("categories")
}

model File {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uploaderId       String       @map("uploader_id") @db.Uuid
  categoryId       String       @map("category_id") @db.Uuid
  title            String       @db.VarChar(120)
  slug             String       @unique @db.VarChar(160)
  description      String       @db.Text
  tags             String[]     @default([])
  license          String       @db.VarChar(80)
  previewImageUrl  String?      @map("preview_image_url") @db.Text
  storagePath      String       @map("storage_path") @db.Text
  originalFileName String       @map("original_file_name") @db.Text
  mimeType         String       @map("mime_type") @db.VarChar(120)
  checksum         String       @unique @db.Text
  fileSize         Int          @map("file_size")
  status           UploadStatus @default(PENDING)
  rarity           RarityLevel  @default(COMMON)
  isFeatured       Boolean      @default(false) @map("is_featured")
  downloadCount    Int          @default(0) @map("download_count")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at")
  reviewedAt       DateTime?    @map("reviewed_at")

  uploader         User         @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  category         Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  uploads          Upload[]
  downloads        Download[]

  @@index([status])
  @@index([rarity])
  @@map("files")
}

model Upload {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  fileId      String       @map("file_id") @db.Uuid
  status      UploadStatus @default(PENDING)
  submittedAt DateTime     @default(now()) @map("submitted_at")
  updatedAt   DateTime     @default(now()) @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  file        File         @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("uploads")
}

model Download {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  fileId       String   @map("file_id") @db.Uuid
  unlockMethod String   @default("rewarded_ad") @map("unlock_method") @db.VarChar(40)
  createdAt    DateTime @default(now()) @map("created_at")

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file         File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("downloads")
}

model AdminLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  adminId    String   @map("admin_id") @db.Uuid
  action     String   @db.VarChar(80)
  entityType String   @map("entity_type") @db.VarChar(80)
  entityId   String   @map("entity_id") @db.Uuid
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_logs")
}

model ScrapedTool {
  id          String   @id @default(uuid())
  title       String
  description String?
  image_url   String?
  webpage_url String   @unique
  category    String
  status      String   @default("pending")
  source_site String?
  scraped_at  DateTime @default(now())
  reviewed_at DateTime?

  @@map("scraped_tools")
}
